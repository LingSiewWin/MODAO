# Anthropic API key for Claude calls.
ANTHROPIC_API_KEY=

# Submitter key — the wallet that pays gas to call submitVerdictAndOpen.
# Distinct from the 5 agent signing keys, which are derived deterministically
# from the shared seed (see src/keys.ts). The submitter just needs MON for gas.
SUBMITTER_PRIVATE_KEY=

# Monad testnet RPC. Override if you want a private endpoint.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Optional. Defaults shown.
VERDICT_DEADLINE_SECONDS=3600
ACTIVE_AGENT_COUNT=5

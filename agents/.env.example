# OpenRouter API key — single key, fans out to 4 model families (Anthropic, OpenAI, Moonshot).
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Pinata JWT for pinning agent reasoning blobs to IPFS.
# Get one at https://app.pinata.cloud/developers/api-keys (use the JWT, not the legacy key/secret).
PINATA_JWT=

# Optional. GitHub PAT raises REST limit from 60/hr (unauth) to 5000/hr.
# `repo:read` scope is enough for public forks. https://github.com/settings/tokens
GITHUB_TOKEN=

# Submitter key — the wallet that pays gas to call submitVerdictAndOpen.
# Distinct from the 4 agent signing keys, which are derived deterministically
# from the shared seed (see src/keys.ts). The submitter just needs MON for gas
# (>= 10 MON to clear the Monad reserve-balance floor — see monskills:concepts).
SUBMITTER_PRIVATE_KEY=

# Monad testnet RPC. Override if you want a private endpoint.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Optional. Defaults shown.
VERDICT_DEADLINE_SECONDS=3600
ACTIVE_AGENT_COUNT=4
